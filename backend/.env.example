# =========================
# Database Configuration
# =========================
DB_HOST=localhost
DB_PORT=5433
DB_NAME=entretien
DB_USERNAME=entretien_user
# IMPORTANT: Change this in production! Never leave as the default.
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =========================
# Server Configuration
# =========================
SERVER_PORT=8080

# =========================
# JWT Configuration
# =========================
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_64+_CHARS
# Access token lifetime in minutes (default fallback: 1440 = 24h)
JWT_ACCESS_MINUTES=1440
JWT_REFRESH_DAYS=30

# =========================
# Cookie Configuration
# =========================
COOKIE_SECURE=true
COOKIE_NAME=refresh_token

# =========================
# SQL Logging (dev only — disable in prod)
# =========================
SHOW_SQL=false
FORMAT_SQL=false
HIBERNATE_LOG_LEVEL=WARN
HIBERNATE_BINDER_LOG_LEVEL=WARN

